# Команда для генерации: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=22f9dffdb5dfd2af12c46d5d441f91873064963592026a9e275895b21ef2901e

# Режим работы
FLASK_ENV=production
FLASK_DEBUG=0

# =============================================================================
# 🗄️ БАЗА ДАННЫХ — абсолютные пути
# =============================================================================
DATABASE_PATH=/var/www/u3498810/data/www/blockchat.ru/blockchain.db

# =============================================================================
# 📁 ФАЙЛЫ И ЗАГРУЗКИ
# =============================================================================
UPLOAD_FOLDER=/var/www/u3498810/data/www/blockchat.ru/uploads
MAX_CONTENT_LENGTH=16777216

# =============================================================================
# 🔐 КРИПТОГРАФИЯ
# =============================================================================
POW_DIFFICULTY=4
POW_MAX_ITERATIONS=1000000
PBKDF2_ITERATIONS=600000
CACHE_SIZE_KEYS=128

# =============================================================================
# 📝 ЛОГИРОВАНИЕ
# =============================================================================
LOG_LEVEL=WARNING
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3

# =============================================================================
# 🍪 SESSION COOKIES (только для HTTPS)
# =============================================================================
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600