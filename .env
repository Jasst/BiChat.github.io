# =============================================================================
# 🔐 БИЗОПАСНОСТЬ И СЕКРЕТЫ
# =============================================================================

# Ключ сессий Flask (минимум 32 символа, генерируйте через secrets.token_hex(32))
# 🔴 НИКОГДА не используйте значение по умолчанию в продакшене!
SECRET_KEY=c77f47f99033625dc6da462f6c00f8c94c7a4a510842045866dc70aba88fa8f4

# Режим работы: production или development
FLASK_ENV=production

# =============================================================================
# 🌐 СЕТЬ И ДОСТУП
# =============================================================================

# Хост для запуска (0.0.0.0 для внешнего доступа, 127.0.0.1 для локального)
FLASK_RUN_HOST=127.0.0.1

# Порт приложения
FLASK_RUN_PORT=5000

# =============================================================================
# 🗄️ БАЗА ДАННЫХ
# =============================================================================

# Путь к файлу базы данных
DATABASE_PATH=blockchain.db

# Таймаут соединений с БД (секунды)
DB_TIMEOUT=30.0

# =============================================================================
# 🔐 КРИПТОГРАФИЯ
# =============================================================================

# Сложность Proof-of-Work (3-5 для dev, 6+ для production)
POW_DIFFICULTY=4

# Максимум итераций PoW (защита от зависания)
POW_MAX_ITERATIONS=1000000

# Размер кэша приватных ключей
CACHE_SIZE_KEYS=128

# Итерации PBKDF2 для деривации ключей (600000 — рекомендация NIST 2024)
PBKDF2_ITERATIONS=600000

# =============================================================================
# 📁 ФАЙЛЫ И ЗАГРУЗКИ
# =============================================================================

# Папка для загруженных файлов
UPLOAD_FOLDER=uploads

# Максимальный размер загружаемого файла (в байтах, 16MB = 16777216)
MAX_CONTENT_LENGTH=16777216

# =============================================================================
# 📝 ЛОГИРОВАНИЕ
# =============================================================================

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Максимальный размер лог-файла перед ротацией (10MB)
LOG_MAX_BYTES=10485760

# Количество резервных копий логов
LOG_BACKUP_COUNT=5

# =============================================================================
# 🚀 ПРОДАКШЕН-НАСТРОЙКИ (раскомментировать для production)
# =============================================================================

# Использовать ли безопасные cookie (только HTTPS)
SESSION_COOKIE_SECURE=true

# Запретить доступ к кукам из JavaScript
SESSION_COOKIE_HTTPONLY=true

# Ограничить отправку кук на same-site запросы
 SESSION_COOKIE_SAMESITE=Lax

# Включить постоянные сессии
PERMANENT_SESSION_LIFETIME=3600